# Local dev works with zero setup (SQLite). Swap to a DO Managed Postgres URL for deployment.
DATABASE_URL=sqlite:///./buzzbuddy.db
# DATABASE_URL=postgresql://user:password@host:25060/buzzbuddy?sslmode=require

# From: DO console -> Inference -> Serverless Inference -> Get Started -> Create a Model Access Key
DIGITAL_OCEAN_MODEL_ACCESS_KEY=your-key-here
DO_MODEL_NAME=anthropic-claude-4.6-sonnet
DO_BASE_URL=https://inference.do-ai.run/v1/

# From: Twilio console -> Account Info (Account SID), Account -> API keys & tokens
# (API Key SID + Secret), Phone Numbers -> Manage -> Active Numbers (from-number)
TWILIO_ACCOUNT_SID=your-account-sid-here
TWILIO_API_KEY_SID=your-api-key-sid-here
TWILIO_API_KEY_SECRET=your-api-key-secret-here
# Separate Account Auth Token used only to validate delivery callbacks.
TWILIO_AUTH_TOKEN=your-account-auth-token-here
TWILIO_FROM_NUMBER=+15555555555

# Public API origin (no trailing slash), used when registering Twilio callbacks.
PUBLIC_BASE_URL=https://your-app.ondigitalocean.app

# Apple Developer -> Certificates, Identifiers & Profiles -> Keys. The .p8
# private key can be provided inline (literal \\n is accepted), base64 encoded, or by path.
APNS_KEY_ID=your-apple-key-id
APNS_TEAM_ID=your-apple-team-id
APNS_BUNDLE_ID=com.yourcompany.buzzbuddy
APNS_PRIVATE_KEY=
APNS_PRIVATE_KEY_BASE64=
APNS_PRIVATE_KEY_PATH=

# Trusted-contact invitations expire after seven days by default.
CONTACT_INVITE_TTL_HOURS=168
NOTIFICATION_TIMEOUT_SECONDS=10
# In-flight provider attempts become "ambiguous" after this lease expires.
NOTIFICATION_ATTEMPT_LEASE_SECONDS=120
