# Local dev works with zero setup (SQLite). Swap to a DO Managed Postgres URL for deployment.
DATABASE_URL=sqlite:///./buzzbuddy.db
# DATABASE_URL=postgresql://user:password@host:25060/buzzbuddy?sslmode=require

# From: DO console -> Inference -> Serverless Inference -> Get Started -> Create a Model Access Key
DIGITAL_OCEAN_MODEL_ACCESS_KEY=your-key-here
DO_MODEL_NAME=anthropic-claude-4.6-sonnet
DO_BASE_URL=https://inference.do-ai.run/v1/
